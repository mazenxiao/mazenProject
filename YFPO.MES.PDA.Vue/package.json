{
  "name": "yfpo-mes-pda-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "YFPO MES PDA 前端升级 —— BS 模式 Vue 3 版本（迭代 1 工程基线）",
  "scripts": {
    "dev": "vite",
    "build": "run-s typecheck build:dist build:version",
    "build:dist": "vite build",
    "build:version": "node scripts/write-version.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --ext .ts,.vue --max-warnings 0",
    "format": "prettier -w \"src/**/*.{ts,vue,css,scss,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen:ops": "tsx scripts/codegen-ops.ts",
    "codegen:models": "tsx scripts/codegen-models.ts"
  },
  "dependencies": {
    "@vueuse/core": "^11.1.0",
    "@zxing/browser": "^0.1.5",
    "axios": "^1.7.7",
    "element-plus": "^2.7.8",
    "pinia": "^2.2.4",
    "uuid": "^10.0.0",
    "vant": "^4.9.4",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.1",
    "vue-router": "^4.4.5",
    "vxe-pc-ui": "^4.14.35",
    "vxe-table": "^4.7.94"
  },
  "devDependencies": {
    "@types/node": "^22.7.6",
    "@types/uuid": "^10.0.0",
    "@vant/auto-import-resolver": "^1.2.1",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.12.0",
    "eslint-plugin-vue": "^9.29.0",
    "happy-dom": "^15.7.4",
    "npm-run-all": "^4.1.5",
    "postcss-px-to-viewport-8-plugin": "^1.2.5",
    "prettier": "^3.3.3",
    "sass": "^1.79.5",
    "terser": "^5.34.1",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.9",
    "vite-plugin-vue-devtools": "^7.4.6",
    "vitest": "^2.1.2",
    "vue-tsc": "^2.1.6"
  }
}
